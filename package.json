{
  "name": "link-site",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "node -e \"const fs=require('fs'); fs.rmSync('.next', {recursive:true, force:true}); fs.rmSync('tsconfig.tsbuildinfo', {force:true})\" && next build --webpack",
    "dev": "next dev --webpack",
    "start": "next start",
    "lint": "eslint",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@opennextjs/cloudflare": "^1.19.11",
    "@prisma/adapter-pg": "^5.22.0",
    "@prisma/adapter-pg-worker": "^6.9.0",
    "@prisma/client": "^5.22.0",
    "@prisma/pg-worker": "^6.9.0",
    "bcryptjs": "^3.0.3",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "next-auth": "^4.24.14",
    "next-themes": "^0.4.6",
    "pg": "^8.21.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-icons": "^5.6.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "postcss": "^8.5.15",
    "prisma": "^5.22.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^5",
    "wrangler": "^4.95.0"
  }
}
